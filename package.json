{
  "name": "@natanimwondwossen/mdconverter",
  "version": "1.0.0",
  "description": "A tool to convert Markdown files to text, PDF, and DOC formats.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --out-dir dist",
    "prepublishOnly": "npm run build",
