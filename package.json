  },
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "markdown-pdf": "^11.0.0",
    "marked": "^17.0.5",
    "puppeteer": "^24.40.0",
    "remove-markdown": "^0.6.3"
  }
